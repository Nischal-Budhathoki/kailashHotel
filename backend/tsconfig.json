{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "node",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "isolatedModules": true,
    "ignoreDeprecations": "6.0",
  },
  "include": ["src"]
}